# --- Django ---
# DJANGO_DEBUG defaults to 1 (on) for local dev; set 0 for any real deployment.
# A SECRET_KEY is only required when DJANGO_DEBUG=0.
DJANGO_DEBUG=1
# SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=*

DATABASE_URL=postgresql://opendir:opendir@localhost:5544/opendir
CENSYS_API_ID=
CENSYS_API_SECRET=
OPENDIR_CONTACT=
OPENDIR_MIN_INTERVAL=1.0
SHODAN_API_KEY=
VT_API_KEY=

# DigitalOcean API token — home orchestrator for the disposable capture/processing
# worker (Full Access). The burner box gets a SEPARATE droplet:delete-only token.
DO_TOKEN=

# droplet:delete-only scoped token — the ONLY DO secret placed on the burner box
# (used solely by its self-destruct timer). Scope this separately in the DO UI.
DO_DELETE_TOKEN=
# ed25519 key already registered on the DO account, and its local private-key path.
DO_SSH_KEY_FINGERPRINT=
DO_SSH_KEY_PATH=~/.ssh/id_ed25519
# Optional droplet defaults.
DO_REGION=nyc3
DO_SIZE=s-1vcpu-1gb

# Secret salt for the report's host-pseudonym HMAC (stable, non-reversible host
# tokens). Generate once:  python -c "import secrets;print(secrets.token_hex(16))"
REPORT_HOST_SALT=
